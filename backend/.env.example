PORT=3001
NODE_ENV=development

# Required — generate real values, never use these placeholders outside local dev:
#   JWT_SECRET:      openssl rand -base64 48
#   INGEST_API_KEY:  openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-secret-at-least-16-chars
INGEST_API_KEY=change-this-to-a-secure-key-at-least-16-chars

# Database - SQLite (default for local dev)
DB_PATH=./data/siem.db

# Database - PostgreSQL (for Docker/production)
# DB_CLIENT=postgres
# DATABASE_URL=postgresql://k3:k3_password@localhost:5432/k3_siem

# WebSocket
WS_PORT=3002

# Ingestion
LOG_INGEST_INTERVAL=3000

# CORS — comma-separated list of allowed origins. Required (non-wildcard) when NODE_ENV=production.
CORS_ORIGIN=http://localhost:3000

# --- Optional: SOAR connectors (no-op/"not configured" until keys are set — see README) ---
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
SERVICENOW_INSTANCE=
SERVICENOW_USER=
SERVICENOW_PASS=
MISP_BASE_URL=
MISP_API_KEY=
PANOS_HOST=
PANOS_API_KEY=
PANOS_BLOCK_GROUP=K3-Blocked-IPs
CROWDSTRIKE_BASE_URL=
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# --- Optional: threat intel feed sync + OSINT lookup panel (no-op until keys are set) ---
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=
NVD_API_KEY=
