# Copy to .env (same directory as docker-compose.yml) before running `docker-compose up`.
# This file is gitignored — never commit real secrets.

# --- Required ---
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=
JWT_SECRET=
# Generate strong values, e.g.:
#   JWT_SECRET:          openssl rand -base64 48
#   INGEST_API_KEY:      openssl rand -hex 32
#   POSTGRES_PASSWORD:   openssl rand -base64 24
#   CLICKHOUSE_PASSWORD: openssl rand -base64 24
INGEST_API_KEY=

# Retention window (days) for high-volume log data in ClickHouse (events table TTL).
EVENTS_RETENTION_DAYS=90
# Real origin(s) of your frontend, comma-separated. Never "*" in production.
CORS_ORIGIN=https://siem.example.com

# Public URL agents/install scripts should use to reach this SIEM (defaults to request host if unset)
SIEM_PUBLIC_URL=

# Synthetic event/alert generator for demos — writes fake rows into the same events/alerts
# tables real agent-ingested data uses. OFF by default under docker-compose (NODE_ENV=production).
# Only set this to true for a sales/demo instance, never for a real monitoring deployment.
DEMO_MODE=false

# --- Optional: SOAR connectors (each is no-op/"not configured" until its keys are set) ---
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
SERVICENOW_INSTANCE=
SERVICENOW_USER=
SERVICENOW_PASS=
MISP_BASE_URL=
MISP_API_KEY=
PANOS_HOST=
PANOS_API_KEY=
PANOS_BLOCK_GROUP=K3-Blocked-IPs
CROWDSTRIKE_BASE_URL=
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# --- Optional: threat intel feed sync (each is no-op until its key is set) ---
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
NVD_API_KEY=
